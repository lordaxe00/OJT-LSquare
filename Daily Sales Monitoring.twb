      <column caption='Channel' datatype='string' default-role='measure' default-type='ordinal' name='[Calculation_387309573661773824]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF UPPER([SegNm])=&quot;AMUSEMENTCTR.&quot; THEN &quot;OTHERS&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;BAKERY&quot; THEN &quot;OTHERS&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;BAKERY/BAKESHOP&quot; THEN &quot;OTHERS&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;BOOK/SCHSUPPLIES&quot; THEN &quot;OTHERS&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;CANTEEN&quot; THEN &quot;OTHERS&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;CANTEEN/CAFETERIA&quot; THEN &quot;OTHERS&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;CARINDERIA&quot; THEN &quot;OTHERS&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;CASH/WALK-IN&quot; THEN &quot;OTHERS&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;CATERER&quot; THEN &quot;OTHERS&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;CHAINCONV.STORE&quot; THEN &quot;CVS&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;CHAINDRUGSTORE&quot; THEN &quot;DRUGSTORE&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;CONVENIENCE STORE&quot; THEN &quot;CVS&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;CONVINIENCE STORE&quot; THEN &quot;CVS&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;CVS&quot; THEN &quot;CVS&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;DISTRIBUTOR&quot; THEN &quot;DISTRIBUTORS&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;DRUG STORE&quot; THEN &quot;DRUGSTORE&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;DRUG STORES&quot; THEN &quot;DRUGSTORE&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;E-COMMERCE&quot; THEN &quot;OTHERS&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;EMPLOYEE&quot; THEN &quot;OTHERS&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;EXPORT&quot; THEN &quot;EXPORT&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;EXPORTER&quot; THEN &quot;EXPORT&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;FACTORYCANTEEN&quot; THEN &quot;OTHERS&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;GOVERNMENT&quot; THEN &quot;INSTITUTIONAL&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;GROCERY&quot; THEN &quot;GROCERY&quot;&#13;&#10;ELSEIF UPPER([SegNm])=&quot;GROCERY - RETAIL&quot; 