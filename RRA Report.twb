        <calculation class='tableau' formula='IF CONTAINS(UPPER([segment]), &apos;GROCERY&apos;) THEN &apos;GROCERY&apos;&#13;&#10;ELSEIF CONTAINS(UPPER([segment]), &apos;SUPERMARKET&apos;) OR CONTAINS(UPPER([segment]), &apos;HYPER&apos;) OR CONTAINS(UPPER([segment]), &apos;SMKT&apos;) OR [segment] = &apos;Wholesaler&apos; THEN &apos;HYPER/SUPERMARKET&apos;&#13;&#10;ELSEIF CONTAINS(UPPER([segment]), &apos;SARI&apos;) OR CONTAINS(UPPER([segment]), &apos;SSS&apos;) THEN &apos;SSS&apos;&#13;&#10;ELSEIF CONTAINS(UPPER([segment]), &apos;DRUG&apos;) THEN &apos;DRUGSTORE&apos;&#13;&#10;ELSEIF CONTAINS(UPPER([segment]), &apos;CVS&apos;) OR CONTAINS(UPPER([segment]), &apos;CONV&apos;) THEN &apos;CVS&apos;&#13;&#10;ELSEIF CONTAINS(UPPER([segment]), &apos;EXPORT&apos;) THEN &apos;EXPORT&apos;&#13;&#10;ELSEIF CONTAINS(UPPER([segment]), &apos;SCHOOL&apos;) THEN &apos;SCHOOLS&apos;&#13;&#10;ELSEIF CONTAINS(UPPER([segment]), &apos;MARKET STALL&apos;) THEN &apos;MARKET STALL&apos;&#13;&#10;ELSEIF [segment] = &apos;Hard Discounters&apos; THEN &apos;HARD DISCOUNTERS&apos;&#13;&#10;ELSEIF [segment] = &apos;Distributor&apos; THEN &apos;DISTRIBUTORS&apos;&#13;&#10;ELSEIF [segment] = &apos;Government&apos; OR [segment] = &apos;Institutional&apos; OR [segment] = &apos;Horeca&apos; THEN &apos;INSTITUTIONAL&apos;&#13;&#10;ELSEIF [segment] = &apos;Rolling Store&apos; OR [segment] = &apos;TRADITIONAL - WHOLESALER&apos; THEN &apos;WHOLESALER&apos;&#13;&#10;ELSE &apos;OTHERS&apos;&#13;&#10;END' />
      </column>
